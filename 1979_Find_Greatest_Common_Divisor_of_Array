class Solution {
public:
    int findGCD(vector<int>& nums) {
        int small_num = nums[0];
        int large_num = nums[0];

        for(int i=0; i < nums.size(); i++){
            if(small_num > nums[i]){
                small_num = nums[i];
            }
            if(large_num < nums[i]){
                large_num = nums[i];
            }
        }
        return gcd(small_num, large_num);
    }
};
