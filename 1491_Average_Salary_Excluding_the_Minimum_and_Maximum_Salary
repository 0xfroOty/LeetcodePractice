class Solution {
public:
    double average(vector<int>& salary) {
        sort(salary.begin(), salary.end());

        int n = salary.size() -2;
        int sum =0;
        double average = 0;
        for(int i=1; i< salary.size() -1; i++){
            sum += salary[i];
        }

        average = (double)sum /n;

        return average;
    }
