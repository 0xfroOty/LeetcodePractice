class Solution {
public:
    vector<int> findDisappearedNumbers(vector<int>& nums) {
        unordered_map <int , int> ans;

        vector<int> sol;

        for(int i=0; i< nums.size(); i++){
            ans[nums[i]]++;
        }

        for(int i=1; i<= nums.size(); i++){
            if(ans[i] == 0){
                sol.push_back(i);
            }
        }
        
        return sol;
    }
};
